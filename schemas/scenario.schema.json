{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zmr.dev/schemas/scenario.schema.json",
  "title": "ZMR Scenario",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "steps"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "appId": { "type": "string", "minLength": 1 },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "$defs": {
    "selector": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "id": { "type": "string" },
        "resourceId": { "type": "string" },
        "text": { "type": "string" },
        "textContains": { "type": "string" },
        "contentDesc": { "type": "string" },
        "contentDescContains": { "type": "string" },
        "className": { "type": "string" }
      }
    },
    "step": {
      "type": "object",
      "required": ["action"],
      "properties": {
        "action": {
          "enum": [
            "launch",
            "stop",
            "clearState",
            "snapshot",
            "openLink",
            "tap",
            "typeText",
            "eraseText",
            "pressBack",
            "hideKeyboard",
            "swipe",
            "waitVisible",
            "waitNotVisible",
            "waitAny",
            "assertVisible",
            "assertNotVisible",
            "optional",
            "whenVisible",
            "repeat",
            "scrollUntilVisible",
            "sleep"
          ]
        },
        "optional": { "type": "boolean" },
        "url": { "type": "string", "minLength": 1 },
        "selector": { "$ref": "#/$defs/selector" },
        "selectors": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/selector" }
        },
        "text": { "type": "string" },
        "maxChars": { "type": "integer", "minimum": 0 },
        "x1": { "type": "integer" },
        "y1": { "type": "integer" },
        "x2": { "type": "integer" },
        "y2": { "type": "integer" },
        "durationMs": { "type": "integer", "minimum": 0 },
        "timeoutMs": { "type": "integer", "minimum": 0 },
        "direction": { "enum": ["down", "up"] },
        "times": { "type": "integer", "minimum": 1 },
        "steps": {
          "type": "array",
          "items": { "$ref": "#/$defs/step" }
        },
        "step": { "$ref": "#/$defs/step" },
        "ms": { "type": "integer", "minimum": 0 }
      },
      "allOf": [
        {
          "if": { "properties": { "action": { "const": "openLink" } } },
          "then": { "required": ["url"] }
        },
        {
          "if": { "properties": { "action": { "enum": ["tap", "waitVisible", "waitNotVisible", "assertVisible", "assertNotVisible", "scrollUntilVisible"] } } },
          "then": { "required": ["selector"] }
        },
        {
          "if": { "properties": { "action": { "const": "waitAny" } } },
          "then": { "required": ["selectors"] }
        },
        {
          "if": { "properties": { "action": { "const": "typeText" } } },
          "then": { "required": ["text"] }
        },
        {
          "if": { "properties": { "action": { "const": "swipe" } } },
          "then": { "required": ["x1", "y1", "x2", "y2"] }
        },
        {
          "if": { "properties": { "action": { "const": "optional" } } },
          "then": { "required": ["step"] }
        },
        {
          "if": { "properties": { "action": { "const": "whenVisible" } } },
          "then": { "required": ["selector", "steps"] }
        },
        {
          "if": { "properties": { "action": { "const": "repeat" } } },
          "then": { "required": ["times", "steps"] }
        }
      ]
    }
  }
}
